# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
*.egg-info/
dist/
build/

# Data files (general)
*.csv
*.xlsx
*.db
*.sqlite

# Logs (general)
*.log

# Endstate generated outputs (not committed)
artifacts/
logs/
plans/
/state/
capture/
payload/
.endstate/

# ---------------------------------------------------------------------------
# Windows Sandbox discovery outputs (generated per run)
# ---------------------------------------------------------------------------
sandbox-tests/discovery/**
!sandbox-tests/discovery/.gitkeep

# ---------------------------------------------------------------------------
# Windows Sandbox validation outputs (generated per run)
# ---------------------------------------------------------------------------
sandbox-tests/validation/**
!sandbox-tests/validation/.gitkeep

# OS
.DS_Store
Thumbs.db
desktop.ini
NUL

# IDE
.vscode/
.idea/
*.swp
*.swo

# Secrets
.env
*.key
*.pem
credentials.json
secrets/

# Temporary files
tmp/
temp/
*.tmp
*~

# Test results
test-results.xml

# Machine-specific captures (not committed)
manifests/local/

# Personal/test manifests at root level (local testing only, not committed)
# Use manifests/examples/ for shareable manifests, manifests/local/ for machine-specific
manifests/*.jsonc
manifests/*.yaml
manifests/*.json
!manifests/.gitkeep

# Personal machine-specific includes (not committed)
manifests/includes/hugo-*

# Examples directory IS committed (shareable, sanitized manifests)
# !manifests/examples/

# Release artifacts (generated at build time, not committed)
VERSION.txt


# Capture output logs (never committed)
capture_output.txt
capture_stderr.txt
capture_stdout.txt

# Trace artifacts (local module generation, never committed)
/trace/
*.generated.jsonc

# Sandbox harness scratch files (never committed)
sandbox-tests/discovery-harness/*.legacy
sandbox-tests/discovery-harness/*.new

# ---------------------------------------------------------------------------
# Winget bootstrap cache (downloaded once, reused across sandbox runs)
# ---------------------------------------------------------------------------
sandbox-tests/.cache/

# ---------------------------------------------------------------------------
# Offline installers (binaries not committed, only README tracked)
# ---------------------------------------------------------------------------
sandbox-tests/installers/*.exe
sandbox-tests/installers/*.msi
sandbox-tests/installers/*.msix
sandbox-tests/installers/*.msixbundle
sandbox-tests/installers/*.appx
sandbox-tests/installers/*.appxbundle
!sandbox-tests/installers/README.md

# Node.js (OpenSpec tooling)
node_modules/
package-lock.json

# Local capture / test artifacts
capture-test.json
test-installed-capture.json
captured-*.jsonc

# Audit script artifacts (generated, not committed)
scripts/audit/*.md
scripts/audit/*.txt
scripts/audit/*.json
scripts/audit-modules-prompt.md

# Go engine build artifacts
go-engine/endstate.exe

