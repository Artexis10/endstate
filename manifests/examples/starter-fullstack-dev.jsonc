{
  // Starter Pack: Full-Stack Dev Rig
  //
  // What's inside: Git, VS Code, Cursor (AI editor), Windows Terminal, WSL,
  // Docker Desktop, Node.js LTS, GitHub CLI, Postman, DBeaver (databases),
  // lazygit, ripgrep, zoxide, Starship prompt, 7-Zip, Claude.
  //
  // One pick per job: Cursor covers the AI-editor slot, Postman the API
  // client, Starship the prompt. Swap to taste — it's just a file.
  //
  // How to apply:
  //   GUI : drag this file onto the Endstate window → Preview → Apply
  //   CLI : endstate apply --profile manifests/examples/starter-fullstack-dev.jsonc

  "version": 1,
  "name": "starter-fullstack-dev",

  "apps": [
    { "id": "git-git",                       "refs": { "windows": "Git.Git" } },
    { "id": "microsoft-visualstudiocode",    "refs": { "windows": "Microsoft.VisualStudioCode" } },
    { "id": "anysphere-cursor",              "refs": { "windows": "Anysphere.Cursor" } },
    { "id": "microsoft-windowsterminal",     "refs": { "windows": "Microsoft.WindowsTerminal" } },
    { "id": "microsoft-wsl",                 "refs": { "windows": "Microsoft.WSL" } },
    { "id": "docker-dockerdesktop",          "refs": { "windows": "Docker.DockerDesktop" } },
    { "id": "openjs-nodejs-lts",             "refs": { "windows": "OpenJS.NodeJS.LTS" } },
    { "id": "github-cli",                    "refs": { "windows": "GitHub.cli" } },
    { "id": "postman-postman",               "refs": { "windows": "Postman.Postman" } },
    { "id": "dbeaver-dbeaver-community",     "refs": { "windows": "DBeaver.DBeaver.Community" } },
    { "id": "jesseduffieldlazygit",          "refs": { "windows": "JesseDuffield.lazygit" } },
    { "id": "burntsushi-ripgrep-msvc",       "refs": { "windows": "BurntSushi.ripgrep.MSVC" } },
    { "id": "ajeetdsouza-zoxide",            "refs": { "windows": "ajeetdsouza.zoxide" } },
    { "id": "starship-starship",             "refs": { "windows": "Starship.Starship" } },
    { "id": "7zip-7zip",                     "refs": { "windows": "7zip.7zip" } },
    { "id": "anthropic-claude",              "refs": { "windows": "Anthropic.Claude" } }
  ],

  "restore": [],
  "verify": []
}
